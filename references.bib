	year = {2024},
	keywords = {Supervised learning, Feature extraction, Detection methods, Crime, Electronic commerce, Self-supervised learning, Rapid growth, Credit card transactions, Fraud detection, COVID-19, Feature engineerings, credit card fraud detection, Credit card fraud detections, Data imbalance, discriminative representation, Discriminative representation, feature engineering, intelligent sampling, Intelligent samplings},
	pages = {1--29},
	annote = {Export Date: 29 May 2026; Cited By: 27; Correspondence Address: S.-H. Huang; Department of Information Management and Finance, National Yang Ming Chiao Tung University, Hsinchu, No. 1001, Daxue Road, East District, Hsinchu City 300093, 300093, Taiwan; email: szuhaohuang@nycu.edu.tw},

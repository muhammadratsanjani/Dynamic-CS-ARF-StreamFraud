@article{abbasiClassImbalanceNetwork2025,
	title = {Class {Imbalance} in {Network} {Traffic} {Classification}: {An} {Adaptive} {Weight} {Ensemble}-of-{Ensemble} {Learning} {Method}},
	volume = {13},
	issn = {21693536 (ISSN)},
	url = {https://www.scopus.com/pages/publications/85217560478?origin=resultslist},
	doi = {10.1109/ACCESS.2025.3538170},
	abstract = {Network Traffic Classification (NTC) serves as a crucial element in network management, and the rapid progress in machine learning has inspired the utilization of learning methods to discern network traffic. The inherent characteristics of network traffics result in uneven class distributions when datasets are shaped, creating a phenomenon known as class imbalance. This phenomenon has garnered growing attention across various research fields. Despite encountering performance setbacks attributed to class imbalance, this challenge remains inadequately examined in the realm of network traffic classification. This paper introduces the Adaptive Weight Ensemble-of-Ensemble Learning (AWEE) method as an innovative solution to this challenge. The AWEE integrates multiple ensemble layers with a dynamic weight adjustment mechanism, showcasing the collaborative intelligence of diverse modeling strategies. Using a sliding window-based validation approach, the model enhances adaptability and robustness to address concept drift in dynamic data streams. Experimental studies on benchmark datasets demonstrate the superior performance of AWEE (achieving an outstanding accuracy rate of over 98\%), highlighting its effectiveness in handling class imbalance challenges across diverse network traffic scenarios. AWEE, outperforms competitive methods, including algorithmic-level, cost-sensitive, and data-level techniques, showcasing its robustness and superior performance in addressing class imbalance challenges across a wide range of network traffic scenarios.  © 2013 IEEE.},
	language = {English},
	journal = {IEEE Access},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Abbasi, M. and Lopez Florez, S. and Shahraki, A. and Taherkordi, A. and Prieto, J. and Corchado, J.M.},
	year = {2025},
	keywords = {Ensemble learning, Performance, class imbalance, Class imbalance, Adversarial machine learning, Contrastive Learning, ensemble learning, Federated learning, Learning methods, Network traffic, In networks, Network traffic classification, Adaptive weights, Application of artificial intelligence, Applications of artificial intelligence, implemented artificial intelligence, Implemented artificial intelligence, network traffic classification},
	pages = {26171--26192},

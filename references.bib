@inproceedings{pengHybridArchitectureUsing2025,
	title = {Hybrid {Architecture} {Using} {Deep} {Auto}-{Encoder} and {Clustering} {Methods} to {Identify} {Diverse} {Transaction} {Anomalies}},
	isbn = {979-833153244-4 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105031120508?origin=resultslist},
	doi = {10.1109/ICCBE65177.2025.11255690},
	abstract = {The rapid expansion of digital payments and online transactions has significantly increased the risk of fraudulent activities in financial systems. Traditional fraud detection models heavily rely on supervised learning, which requires large-scale labeled datasets. However, due to the dynamic nature of fraud techniques, it is impractical to continuously update supervised models with new fraud patterns. Therefore, we developed a hybrid anomaly detection model that integrates a deep auto-encoder (DAE) with other unsupervised techniques to effectively identify and categorize anomalous financial transactions. In the developed model, traditional machine learning models such as a decision tree, a random forest, and XGBoost are used as baseline models to compare unsupervised learning results. The model based on DAE extracts the latent feature representations of financial transactions, followed by anomaly detection using an isolation forest and a one-class support vector machine (SVM) based on the DAE's encoded representations. Additionally, we also applied isolation forest and one-class SVM directly on the same test set without the DAE's latent features as input. This cross-comparison approach validates the adaptability of different models in credit card transaction anomaly detection and facilitates the discovery of novel fraud patterns that deviate from known behaviors. The performance of the hybrid model developed was tested on a real-world-based simulated bank transaction dataset generated using Sparkov data generation tool. The performance was compared with that of standalone supervised models, standard auto-encoder methods, and traditional unsupervised learning techniques. The results demonstrated that the deep auto-encoder + isolation forest hybrid model developed in this study showed a balanced performance, particularly in adapting to concept drift and discovered hidden anomalous behaviors in specific demographic and geographic transaction patterns. Integrating deep learning with hybrid learning strategies offers a powerful and interpretable solution for financial institutions to enhance risk management and fraud prevention efforts. © 2025 IEEE.},
	language = {English},
	booktitle = {Proc. {IEEE} {Int}. {Conf}. {Comput}., {Big}-{Data} {Eng}., {ICCBE}},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Peng, T. and Cheng, Y.-J.},
	editor = {{Meen T.-H.}},
	year = {2025},
	note = {Journal Abbreviation: Proc. IEEE Int. Conf. Comput., Big-Data Eng., ICCBE},
	keywords = {Anomaly detection, Concept drifts, Decision trees, Finance, Learning systems, Supervised learning, Statistical tests, Large datasets, Cluster analysis, Online systems, Auto encoders, Random forests, Deep learning, concept drift adaptation, Concept drift adaptation, Labeled data, Crime, Unsupervised learning, unsupervised learning, Forestry, Pattern recognition, Behavioral research, Fraud detection, isolation forest, Isolation forest, Electronic money, cold start anomaly detection, Cold start anomaly detection, Cold-start, credit card fraud detection, Credit card fraud detections, deep auto-encoder, Deep auto-encoder, hybrid fraud detection, Hybrid fraud detection, Risk management, Signal encoding},
	pages = {584--589},
	annote = {Export Date: 29 May 2026; Cited By: 0; Correspondence Address: T. Peng; National Taipei University of Technology, Department of Information and Financial Management, Taipei, Taiwan; email: johnpeng@mail.ntut.edu.tw},
}

@article{allawatiIntegratedPreprocessingDrift2025,
	title = {An {Integrated} {Preprocessing} and {Drift} {Detection} {Approach} {With} {Adaptive} {Windowing} for {Fraud} {Detection} in {Payment} {Systems}},
	volume = {13},
	issn = {21693536 (ISSN)},
	url = {https://www.scopus.com/pages/publications/105005082418?origin=resultslist},
	doi = {10.1109/ACCESS.2025.3569609},
	abstract = {As fraudulent transaction methods evolve rapidly; it becomes progressively more challenging to detect them in payment systems. Static machine learning and rule-based traditional detection methods cannot capture all the dynamic and evolving nature of fraudulent behaviors, resulting in lower detection accuracy and a higher false positive rate. This study proposes a complete framework that brings together advanced data preprocessing, effective drift detection, and a reliable detection model to address these issues. The method uses Mutual Information and SelectKBest for selecting important features, applies ADASYN to handle class imbalance, and adopts Convolutional Neural Networks (CNN) to capture complex transaction patterns. By implementing Early Drift Detection Method (EDDM) and ADaptive WINdowing (ADWIN), the drift can be detected in advance and the system can respond to changes, both gradual and sudden.The framework was evaluated on three datasets, including real-world transactions and mixed-data environments, achieving superior accuracy, precision, and drift detection rates, with values up to 99.99\% accuracy and 1.0 respectively. The findings show that the framework can adjust to changing patterns of fraud, reduce false positives, and enhance detection performance. These insights demonstrate the significance of dynamic pre-processing and drift-aware approaches in the context of real-time fraud detection. This also serves as a basis for future work in adaptive fraud detection model research areas such as of integrating online learning for improved speed and efficiency in high-frequency transactional environments. © 2025 The Authors.},
	language = {English},
	journal = {IEEE Access},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Al Lawati, H.M.R. and Zainal, A. and Al-Rimy, B.A.S. and Al-Azawi, M. and Kassim, M.N. and Almalki, S.A. and Alghamdi, T.A.},
	year = {2025},
	keywords = {Concept drifts, Supervised learning, concept drift, class imbalance, Class imbalance, Drift detection, Data preprocessing, Real- time, Deep learning, drift detection, deep learning, Feature Selection, Features selection, Convolutional neural networks, Fraud detection, fraud detection, Banking fraud, credit cards, Credit cards, data pre-processing, debit cards, Debit cards, payment systems, Payment systems, Prepaid card, prepaid cards, real-time fraud detection, Real-time fraud detection, supervised feature selection, Supervised feature selection},
	pages = {92036--92056},
	annote = {Export Date: 29 May 2026; Cited By: 11; Correspondence Address: A. Zainal; Faculty of Computing, Universiti Teknologi Malaysia (UTM), Johor Bahru, 81310, Malaysia; email: anazida@utm.my},
}

@inproceedings{moradiEnsembleBasedFraudDetection2025,
	title = {Ensemble-{Based} {Fraud} {Detection}: {A} {Robust} {Approach} {Evaluated} on {IEEE}-{CIS}},
	isbn = {979-833158973-8 (ISBN)},
	url = {https://www.scopus.com/pages/publications/105030442249?origin=resultslist},
	doi = {10.1109/ICCKE68588.2025.11273852},
	abstract = {Credit card fraud has increased with the fast expansion of online financial transactions, requiring the implementation of advanced detection systems. According to the IEEE-CIS dataset, this paper presents an extensive empirical assessment of ensemble learning methods for class-imbalanced fraud detection. By evaluating ensemble techniques such as Random Forest, XGBoost, LightGBM, and stacking approaches systematically, we address the critical issues of extreme class imbalance, concept drift, and real-time detection requirements. Our solution involves comprehensive feature engineering strategies tuned to the IEEE-CIS dataset, which consists of 590,540 transactions with a fraud rate of 3.5\%, as well as advanced data balancing techniques (SMOTE, ADASYN, and Borderline-SMOTE). From experimental results, our ensemble stacking approach maintains low false positive rates while fraud is detected at high rates (0.918 AUC-ROC, 0.891 AUC-PR) and outperforms. The study offers useful implications for real-world practical implementation and empirical proof of the proficiency of ensemble approaches in dealing with highly imbalanced financial fraud datasets.  © 2025 IEEE.},
	language = {English},
	booktitle = {Int. {Conf}. {Comput}. {Knowl}. {Eng}., {ICCKE}},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	author = {Moradi, F. and Tarif, M. and Homaei, M.},
	year = {2025},
	note = {Journal Abbreviation: Int. Conf. Comput. Knowl. Eng., ICCKE},
	keywords = {Ensemble learning, Classification (of information), Finance, Learning systems, Machine-learning, Online systems, Artificial intelligence, Machine Learning, Crime, Stackings, Credit card frauds, Fraud detection, Balancing, Credit card fraud detections, Credit Card Fraud Detection, Financial security, Financial Security, IEEE-CIS dataset, IEEE-CIS Dataset, Imbalanced classification, Imbalanced Classification, Robust approaches},
